{
  "compilerOptions": {
    "declaration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "paths": {
      "proto/*": ["./proto/*"],
      "client/*": ["./client/*"],
      "truescrub/*": ["./truescrub/*"],
      "../google/type/*": [
        "./node_modules/@buf/googleapis_googleapis.bufbuild_es/google/type/*"
      ]
    },
    "jsx": "react-jsx",
    "sourceMap": false,
    "strict": true,
    "target": "ESNext",
    "resolveJsonModule": true
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
